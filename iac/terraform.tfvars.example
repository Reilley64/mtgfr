# Copy to terraform.tfvars or *.auto.tfvars (both gitignored) and fill in.
# See variables.tf for the full list + descriptions. Defaults in variables.tf use example.com;
# override hostnames here for a real deploy.

kubeconfig_path = "~/.kube/config"

cloudflare_account_id = "REPLACE_WITH_CLOUDFLARE_ACCOUNT_ID"
cloudflare_zone_id    = "REPLACE_WITH_CLOUDFLARE_ZONE_ID"
cloudflare_api_token  = "REPLACE_WITH_CLOUDFLARE_API_TOKEN"

dns_zone     = "example.com"
edh_hostname = "edh.example.com"

# Same-origin BFF: host-only session cookie; CORS unused for the browser.
cookie_domain = ""
cors_origin   = ""

# Versioned API: set desired active + web images. Argo syncs Deployments; old API pods drain on SIGTERM.
server_image = "ghcr.io/OWNER/mtgfr-server:0.1.0"
# api_termination_grace_seconds = 86400

web_image = "ghcr.io/OWNER/mtgfr-web:0.1.0"

# Required — Argo Application source for API/web Deployments + edh-api Service (iac/charts/edh).
# targetRevision must already contain the chart templates before the first Argo-owned apply.
argocd_repo_url        = "https://github.com/OWNER/mtgfr.git"
argocd_target_revision = "main"

mtgfr_db_password = "e5db11cd56bb69063d88f6434463198837d33f9cadd5d8fb70f20ccbd2a5945d"

# Reserved — session signing if added later; leave empty until the server consumes it.
auth_secret = ""

# Pin cloudflared to an explicit release — never "latest". Check
# https://github.com/cloudflare/cloudflared/releases for the current stable tag.
cloudflared_image = "cloudflare/cloudflared:2026.6.0"
