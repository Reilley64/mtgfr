{
  "name": "mtgfr-client",
  "private": true,
  "type": "module",
  "scripts": {
    "gen": "PATH=\"$PWD/node_modules/.bin:$PATH\" bunx --bun buf generate --template ../proto/buf.gen.yaml ../proto",
    "predev": "bun run gen",
    "dev": "vinxi dev",
    "prebuild": "bun run gen",
    "build": "tsc --noEmit && vinxi build",
    "start": "vinxi start",
    "preview": "vinxi preview",
    "pretest": "bun run gen",
    "pretypecheck": "bun run gen",
    "test": "vitest run",
    "migrate": "sh scripts/migrate.sh",
    "lint": "biome check --formatter-enabled=false",
    "lint:fix": "biome check --write --formatter-enabled=false",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2",
    "@connectrpc/connect": "^2",
    "@connectrpc/connect-node": "^2",
    "@effect-grpc/effect-grpc": "npm:@effect-grpc/effect-grpc@1.0.0-beta.2",
    "@effect/atom-solid": "4.0.0-beta.94",
    "@effect/opentelemetry": "4.0.0-beta.94",
    "@effect/sql-pg": "4.0.0-beta.94",
    "@grafana/faro-web-sdk": "^2.8.2",
    "@grafana/faro-web-tracing": "^2.8.2",
    "@opentelemetry/exporter-logs-otlp-http": "^0.220.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-logs": "^0.220.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@opentelemetry/sdk-trace-node": "^2.9.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.16.1",
    "@solidjs/start": "1.3.2",
    "clsx": "2.1.1",
    "cva": "1.0.0-beta.7",
    "drizzle-orm": "^0.45.2",
    "effect": "4.0.0-beta.94",
    "mana-font": "1.18.0",
    "solid-js": "^1.9.14",
    "tailwind-merge": "3.6.0",
    "vinxi": "^0.5.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@bufbuild/buf": "^1",
    "@bufbuild/protoc-gen-es": "^2",
    "@effect-grpc/codegen": "npm:@effect-grpc/codegen@1.0.0-beta.2",
    "@effect-grpc/protoc-gen-effect-grpc": "npm:@effect-grpc/protoc-gen-effect-grpc@1.0.0-beta.2",
    "@effect/language-service": "^0.87.0",
    "@effect/platform-node": "4.0.0-beta.94",
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "26.1.0",
    "drizzle-kit": "^0.31.10",
    "happy-dom": "15",
    "tailwindcss": "4.3.2",
    "typescript": "^6.0.3",
    "vite": "^6.3.3",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22",
    "bun": "1.3.14"
  },
  "packageManager": "bun@1.3.14"
}
